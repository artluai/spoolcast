node_modules
dist
build
.DS_Store
.env

# Ignore the output video from Git but not videos you import into src/.
out

# Generated review-board media should not be committed.
public/*/review-preview

# Remotion static-file mount — these are per-session symlinks created by
# scripts/init_session.py, not real files. Different users / sessions will
# have different targets.
public/frames
public/source
public/pilot

# Generated by scripts/build_preview_data.py — regenerate locally; don't commit.
# Covers preview-data.json + any versioned backups like preview-data.v0.json.
src/data/preview-data*.json

# python sandbox for scripts/
scripts/.venv/
__pycache__/
*.pyc

# google cloud credentials — never commit
.gcloud-tts-key.json
*.gcloud-tts-key.json

# YouTube OAuth token cache (lives in ~/.config by default, but just in case
# someone re-points it into the repo, guard against the commit).
youtube-token.json
