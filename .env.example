# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# --- REQUIRED ---

# kie.ai — image generation (nano-banana-2 and other models)
# Get a key at https://kie.ai/
KIE_API_KEY=your-kie-ai-key-here

# Google Cloud Text-to-Speech — narration (Chirp3-HD-Puck and other voices)
# Enable the Text-to-Speech API in a GCP project, create an API key, paste here.
# https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_CLOUD_TTS_API_KEY=your-gcp-tts-key-here

# ElevenLabs — adapter coming soon. Fill these in now if you want to be
# ready when the adapter ships. Until then, tts_client.py uses Google TTS.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
# ELEVENLABS_STABILITY=0.5
# ELEVENLABS_SIMILARITY_BOOST=0.75
# ELEVENLABS_STYLE=0.0
# ELEVENLABS_USE_SPEAKER_BOOST=true


# --- OPTIONAL — stock broll (alternate-mode fetch via scripts) ---

# Pexels free API — video/photo search for broll chunks when not using
# the illustrated-scene default. Get a key at https://www.pexels.com/api/
# PEXELS_API_KEY=


# --- OPTIONAL — narration auditor (scripts/audit_narration.py) ---

# Claude Haiku path — cleanest output, ~$0.25 per audit run.
# Get a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# Qwen via OpenRouter path — cheaper, ~$0.03 per audit run, noisier on archetype
# recognition. Get a key at https://openrouter.ai/settings/keys
# OPENROUTER_API_KEY=sk-or-v1-...


# --- OPTIONAL — YouTube upload (scripts/publish_youtube.py) ---

# Path to the client_secret.json downloaded from Google Cloud Console
# (Project → OAuth 2.0 Client IDs → Desktop app → download JSON).
# First run opens a browser for consent; refresh token is cached at
# ~/.config/spoolcast/youtube-token.json so subsequent runs are silent.
# YOUTUBE_CLIENT_SECRETS_PATH=/absolute/path/to/client_secret.json
